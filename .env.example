# Local LLM (OpenAI-compatible, e.g. LM Studio, Ollama, vLLM)
LOCALLLM_API_KEY=sk-LocalHost
LOCALLLM_BASE_URL=http://192.168.0.124:8080/v1
LOCALLLM_MODEL=QwenCoder
LOCALLLM_PREFILL=<|channel|>thought\nМоя задача — перевести текст с английского на русский языки. Я выдаю ТОЛЬКО перевод, без пояснений и оригинального текста. Сохраняю всю пунктуацию. <|channel|>

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_PREFILL=

# --- Как добавить нового провайдера ---
# 1. Добавь блок <ИМЯ>_API_KEY, <ИМЯ>_BASE_URL, <ИМЯ>_MODEL, <ИМЯ>_PREFILL сюда
# 2. Добавь запись в PROVIDERS в config.py по тому же шаблону
# 3. Ссылайся на него по имени в TRANSLATION_CHAIN

# LibreTranslate fallback
LIBRETRANSLATE_URL=https://libretranslate.com/translate
LIBRETRANSLATE_API_KEY=

# Behaviour
LOG_TRANSLATION_CONTENT=false
